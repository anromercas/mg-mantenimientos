---
import Icon from './icons/Icon.astro';
import { site } from '../data/site';

interface Props {
  phone?: 'desatascos' | 'plagas';
  label?: string;
  class?: string;
}

const {
  phone = 'desatascos',
  label = 'Llamar ahora — 24h',
  class: className = '',
} = Astro.props;

const tel =
  phone === 'desatascos' ? site.telefonos.desatascosTel : site.telefonos.plagasTel;
---

<a
  href={`tel:${tel}`}
  class={`inline-flex items-center justify-center gap-2 rounded-full bg-dark px-6 py-3 font-display text-sm font-bold text-white shadow-lg shadow-black/20 transition hover:bg-black ${className}`}
>
  <Icon name="phone" class="h-5 w-5" />
  {label}
</a>
