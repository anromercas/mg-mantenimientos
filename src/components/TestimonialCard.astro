---
import Icon from './icons/Icon.astro';

interface Props {
  quote: string;
  author?: string;
}

const { quote, author = 'Cliente en Google' } = Astro.props;
---

<figure class="rounded-2xl border border-black/5 bg-white p-8 shadow-sm">
  <div class="flex gap-1 text-accent">
    {Array.from({ length: 5 }).map(() => <Icon name="star" class="h-5 w-5" />)}
  </div>
  <blockquote class="mt-4 text-lg leading-relaxed text-ink/80">
    "{quote}"
  </blockquote>
  <figcaption class="mt-4 font-display text-sm font-bold text-primary">
    — {author}
  </figcaption>
</figure>
