---
import Icon from './icons/Icon.astro';

interface Props {
  icon:
    | 'pipe'
    | 'camera-360'
    | 'shield'
    | 'bug'
    | 'rat'
    | 'spray'
    | 'water-drop'
    | 'termite';
  title: string;
  description: string;
  items: readonly string[];
  href: string;
}

const { icon, title, description, items, href } = Astro.props;
---

<article class="flex flex-col rounded-2xl border border-black/5 bg-white p-8 shadow-sm transition hover:shadow-md">
  <div class="flex h-14 w-14 items-center justify-center rounded-xl bg-primary/5 text-primary">
    <Icon name={icon} class="h-8 w-8" />
  </div>
  <h3 class="mt-6 font-display text-2xl font-bold text-primary">{title}</h3>
  <p class="mt-3 text-ink/70">{description}</p>
  <ul class="mt-5 space-y-2">
    {
      items.map((item) => (
        <li class="flex items-start gap-2 text-sm text-ink/80">
          <Icon name="check" class="mt-0.5 h-4 w-4 shrink-0 text-accent" />
          {item}
        </li>
      ))
    }
  </ul>
  <a
    href={href}
    class="mt-6 inline-flex items-center gap-2 font-display text-sm font-bold text-accent hover:underline"
  >
    Ver más
    <Icon name="arrow-right" class="h-4 w-4" />
  </a>
</article>
