---
import Icon from './icons/Icon.astro';
import { site } from '../data/site';

const year = new Date().getFullYear();
---

<footer class="bg-primary text-white/90">
  <div class="mx-auto grid max-w-7xl gap-10 px-4 py-12 sm:px-6 md:grid-cols-3 lg:px-8">
    <div>
      <p class="flex items-center gap-2 font-display text-lg font-bold text-white">
        <Icon name="pipe" class="h-6 w-6 text-accent" />
        MG Mantenimientos
      </p>
      <p class="mt-3 text-sm text-white/70">
        Desatascos, saneamiento y control de plagas en Sevilla. Más de 25 años
        de experiencia, autorizados por la Junta de Andalucía.
      </p>
      <div class="mt-4 flex gap-3">
        <a
          href={site.redesSociales.facebook}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Facebook de MG Mantenimientos"
          class="flex h-9 w-9 items-center justify-center rounded-full bg-white/10 transition hover:bg-accent"
        >
          <Icon name="facebook" class="h-4 w-4" />
        </a>
        <a
          href={site.redesSociales.twitter}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Twitter de MG Mantenimientos"
          class="flex h-9 w-9 items-center justify-center rounded-full bg-white/10 transition hover:bg-accent"
        >
          <Icon name="twitter" class="h-4 w-4" />
        </a>
      </div>
    </div>

    <div>
      <p class="font-display text-sm font-bold uppercase tracking-wide text-white">
        Contacto
      </p>
      <ul class="mt-3 space-y-2 text-sm text-white/70">
        <li class="flex items-start gap-2">
          <Icon name="map-pin" class="mt-0.5 h-4 w-4 shrink-0 text-accent" />
          {site.direccion.completa}
        </li>
        <li class="flex items-center gap-2">
          <Icon name="phone" class="h-4 w-4 shrink-0 text-accent" />
          <a href={`tel:${site.telefonos.desatascosTel}`} class="hover:text-white">
            {site.telefonos.desatascos} (Desatascos)
          </a>
        </li>
        <li class="flex items-center gap-2">
          <Icon name="phone" class="h-4 w-4 shrink-0 text-accent" />
          <a href={`tel:${site.telefonos.plagasTel}`} class="hover:text-white">
            {site.telefonos.plagas} (Control de plagas)
          </a>
        </li>
        <li class="flex items-center gap-2">
          <Icon name="clock" class="h-4 w-4 shrink-0 text-accent" />
          {site.horario}
        </li>
      </ul>
      <a
        href={site.googleMapsUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-3 inline-flex items-center gap-1 text-sm font-semibold text-accent hover:underline"
      >
        Ver ficha en Google Maps ({site.valoracionGoogle.rating}★, {site.valoracionGoogle.numReviews} reseñas)
      </a>
    </div>

    <div>
      <p class="font-display text-sm font-bold uppercase tracking-wide text-white">
        Enlaces
      </p>
      <ul class="mt-3 space-y-2 text-sm text-white/70">
        <li><a href="/aviso-legal/" class="hover:text-white">Aviso legal</a></li>
        <li><a href="/politica-privacidad/" class="hover:text-white">Política de privacidad</a></li>
        <li><a href="/cookies/" class="hover:text-white">Política de cookies</a></li>
        <li><a href="/blog/" class="hover:text-white">Blog</a></li>
      </ul>
    </div>
  </div>

  <div class="border-t border-white/10 py-4 text-center text-xs text-white/50">
    © {year} {site.nombre}. Todos los derechos reservados.
  </div>
</footer>
