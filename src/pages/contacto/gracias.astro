---
import BaseLayout from '../../layouts/BaseLayout.astro';
import UrgentCTA from '../../components/UrgentCTA.astro';
import Icon from '../../components/icons/Icon.astro';
---

<BaseLayout
  title="Mensaje enviado | MG Mantenimientos Sevilla"
  description="Hemos recibido tu mensaje. Nuestro equipo te contactará lo antes posible."
>
  <section class="mx-auto flex max-w-2xl flex-col items-center px-4 py-24 text-center sm:px-6 lg:px-8">
    <div class="flex h-16 w-16 items-center justify-center rounded-full bg-accent/10 text-accent">
      <Icon name="check" class="h-8 w-8" />
    </div>
    <h1 class="mt-6 font-display text-3xl font-bold text-primary sm:text-4xl">
      ¡Gracias por contactarnos!
    </h1>
    <p class="mt-3 text-lg text-ink/70">
      Hemos recibido tu mensaje y nuestro equipo te contactará lo antes
      posible. Si tu caso es urgente, llámanos directamente.
    </p>
    <div class="mt-8">
      <UrgentCTA />
    </div>
  </section>
</BaseLayout>
