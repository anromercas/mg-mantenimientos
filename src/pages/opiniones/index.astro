---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TestimonialCard from '../../components/TestimonialCard.astro';
import Icon from '../../components/icons/Icon.astro';
import { site } from '../../data/site';
---

<BaseLayout
  title="Opiniones de Clientes | MG Mantenimientos Sevilla"
  description={`Valorados con ${site.valoracionGoogle.rating}★ en Google por más de ${site.valoracionGoogle.numReviews} clientes. Descubre las opiniones sobre nuestros servicios de desatascos y control de plagas en Sevilla.`}
>
  <section class="mx-auto max-w-4xl px-4 py-16 text-center sm:px-6 lg:px-8">
    <h1 class="font-display text-4xl font-bold text-primary sm:text-5xl">
      Opiniones de nuestros clientes
    </h1>

    <div class="mt-8 inline-flex flex-col items-center gap-2 rounded-2xl bg-white px-10 py-8 shadow-sm">
      <div class="flex gap-1 text-accent">
        {Array.from({ length: 5 }).map(() => <Icon name="star" class="h-7 w-7" />)}
      </div>
      <p class="font-display text-4xl font-bold text-primary">
        {site.valoracionGoogle.rating} / 5
      </p>
      <p class="text-ink/60">
        Basado en {site.valoracionGoogle.numReviews} reseñas en Google
      </p>
      <a
        href={site.googleMapsUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-2 inline-flex items-center gap-2 rounded-full bg-primary px-5 py-2.5 text-sm font-bold text-white hover:bg-primary-dark"
      >
        Ver todas las reseñas en Google Maps
        <Icon name="arrow-right" class="h-4 w-4" />
      </a>
    </div>
  </section>

  <section class="mx-auto max-w-5xl px-4 pb-16 sm:px-6 lg:px-8">
    <div class="grid gap-6 md:grid-cols-2">
      <TestimonialCard quote="Nos solucionaron un atasco complicado en pocas horas, con un trato muy profesional. Totalmente recomendable." />
      <TestimonialCard quote="Vinieron rápido para un atasco importante y además nos asesoraron sobre mantenimiento y el seguro del hogar. Un servicio excelente." />
    </div>
    <p class="mt-6 text-center text-sm text-ink/50">
      Reseñas adaptadas de opiniones reales de clientes en Google. Pendiente de
      confirmación literal con el cliente antes de publicación definitiva.
    </p>
  </section>
</BaseLayout>
