---
import BaseLayout from '../layouts/BaseLayout.astro';
import UrgentCTA from '../components/UrgentCTA.astro';
---

<BaseLayout
  title="Página no encontrada | MG Mantenimientos"
  description="La página que buscas no existe o se ha movido."
>
  <section class="mx-auto flex max-w-2xl flex-col items-center px-4 py-24 text-center sm:px-6 lg:px-8">
    <p class="font-display text-6xl font-bold text-accent">404</p>
    <h1 class="mt-4 font-display text-3xl font-bold text-primary sm:text-4xl">
      No hemos encontrado esta página
    </h1>
    <p class="mt-3 text-lg text-ink/70">
      Puede que el enlace esté roto o que la página se haya movido. Vuelve al
      inicio o llámanos si necesitas ayuda urgente.
    </p>
    <div class="mt-8 flex flex-wrap justify-center gap-4">
      <a
        href="/"
        class="inline-flex items-center gap-2 rounded-full border border-primary/20 px-6 py-3 font-display text-sm font-bold text-primary transition hover:bg-primary/5"
      >
        Volver al inicio
      </a>
      <UrgentCTA />
    </div>
  </section>
</BaseLayout>
