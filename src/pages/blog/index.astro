---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/icons/Icon.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const formatter = new Intl.DateTimeFormat('es-ES', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<BaseLayout
  title="Blog | Desatascos y Control de Plagas en Sevilla | MG Mantenimientos"
  description="Consejos y artículos sobre desatascos, saneamiento y control de plagas en Sevilla, escritos por el equipo de MG Mantenimientos."
>
  <section class="mx-auto max-w-5xl px-4 py-16 sm:px-6 lg:px-8">
    <h1 class="font-display text-4xl font-bold text-primary sm:text-5xl">
      Blog
    </h1>
    <p class="mt-3 max-w-2xl text-lg text-ink/70">
      Consejos prácticos sobre desatascos, saneamiento y control de plagas en
      Sevilla.
    </p>

    <div class="mt-12 grid gap-6 sm:grid-cols-2">
      {
        posts.map((post) => (
          <a
            href={`/blog/${post.id}/`}
            class="flex flex-col rounded-2xl border border-black/5 bg-white p-6 shadow-sm transition hover:shadow-md"
          >
            <p class="text-xs font-semibold uppercase tracking-wide text-accent">
              {formatter.format(post.data.pubDate)}
            </p>
            <h2 class="mt-2 font-display text-xl font-bold text-primary">
              {post.data.title}
            </h2>
            <p class="mt-2 flex-1 text-sm text-ink/70">{post.data.description}</p>
            <span class="mt-4 inline-flex items-center gap-1 text-sm font-bold text-accent">
              Leer artículo
              <Icon name="arrow-right" class="h-4 w-4" />
            </span>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
