---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ServiceCard from '../components/ServiceCard.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import UrgentCTA from '../components/UrgentCTA.astro';
import WhatsAppCTA from '../components/WhatsAppCTA.astro';
import Icon from '../components/icons/Icon.astro';
import { site } from '../data/site';
import fotoFurgoneta from '../assets/fotos/furgoneta-desatascos-control-plagas-sevilla.jpg';
import fotoTecnicoDesatascos from '../assets/fotos/tecnico-desatasco-arqueta-sevilla.jpg';
import fotoTecnicoPlagas from '../assets/fotos/tecnico-control-plagas-tratamiento-sevilla.jpg';
---

<BaseLayout
  title="Desatascos y Control de Plagas en Sevilla, 24h | MG Mantenimientos"
  description="Desatascos urgentes y control de plagas en Sevilla, 24 horas los 365 días. Más de 25 años de experiencia, autorizados por la Junta de Andalucía. 4.6★ en Google."
>
  <Hero
    title="Desatascos y Control de Plagas en Sevilla, 24 horas los 365 días del año"
    subtitle="Más de 25 años resolviendo urgencias en Sevilla capital. Empresa autorizada por la Junta de Andalucía. Valorados con 4.6★ en Google por más de 60 clientes."
    image={fotoFurgoneta}
    imageAlt="Furgoneta rotulada de MG Mantenimientos con los teléfonos de desatascos y control de plagas, servicio 24 horas en Sevilla"
  />

  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        site.diferenciadores.slice(0, 4).map((d) => (
          <div class="flex items-start gap-3 rounded-xl bg-white p-5 shadow-sm">
            <Icon name="shield" class="h-6 w-6 shrink-0 text-accent" />
            <p class="text-sm font-medium text-ink/80">{d}</p>
          </div>
        ))
      }
    </div>
  </section>

  <section class="bg-white py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl">
        <h2 class="font-display text-3xl font-bold text-primary sm:text-4xl">
          Nuestros servicios
        </h2>
        <p class="mt-3 text-ink/70">
          Dos especialidades, un mismo compromiso: rapidez, garantía y precio justo.
        </p>
      </div>
      <div class="mt-10 grid gap-8 md:grid-cols-2">
        <ServiceCard
          icon="pipe"
          title="Desatascos y saneamiento"
          description="Desatascos urgentes con inspección por cámara 360º para localizar la avería sin necesidad de obra."
          items={site.servicios.desatascos}
          href="/desatascos-sevilla/"
          image={fotoTecnicoDesatascos}
          imageAlt="Técnico de MG Mantenimientos realizando un desatasco en una arqueta en Sevilla"
        />
        <ServiceCard
          icon="shield"
          title="Control de plagas"
          description="Desinsectación, desratización y tratamientos antitermitas con empresa autorizada por la Junta de Andalucía."
          items={site.servicios.plagas}
          href="/control-plagas-sevilla/"
          image={fotoTecnicoPlagas}
          imageAlt="Técnico de MG Mantenimientos aplicando un tratamiento de control de plagas en un local de Sevilla"
        />
      </div>

      <a
        href="/servicios/#abono"
        class="mt-10 flex flex-col items-start gap-3 rounded-2xl border-2 border-primary/20 bg-primary/5 p-6 transition hover:border-primary/40 sm:flex-row sm:items-center sm:justify-between"
      >
        <div>
          <p class="font-display text-lg font-bold text-primary">
            ¡Contrata nuestro pack Desatascos + Control de Plagas y ahorra!
          </p>
          <p class="mt-1 text-sm text-ink/70">
            Mantenimiento anual con prevención y solución de problemas durante
            todo el año.
          </p>
        </div>
        <span class="inline-flex shrink-0 items-center gap-2 rounded-full bg-primary px-6 py-3 font-display text-sm font-bold text-white">
          Abónate
          <Icon name="arrow-right" class="h-4 w-4" />
        </span>
      </a>
    </div>
  </section>

  <section id="opiniones" class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="flex flex-col gap-6 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <h2 class="font-display text-3xl font-bold text-primary sm:text-4xl">
          Lo que dicen nuestros clientes
        </h2>
        <div class="mt-3 flex items-center gap-2">
          <span class="flex gap-0.5 text-amber-400">
            {Array.from({ length: 5 }).map(() => <Icon name="star" class="h-5 w-5" />)}
          </span>
          <span class="font-display font-bold text-ink">
            {site.valoracionGoogle.rating} / 5
          </span>
          <span class="text-sm text-ink/60">
            · {site.valoracionGoogle.numReviews} reseñas en Google
          </span>
        </div>
      </div>
      <a
        href={site.googleMapsUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex shrink-0 items-center gap-2 rounded-full bg-primary px-5 py-2.5 font-display text-sm font-bold text-white transition hover:bg-primary-dark"
      >
        Ver todas en Google Maps
        <Icon name="arrow-right" class="h-4 w-4" />
      </a>
    </div>

    <div
      class="-mx-4 mt-10 flex snap-x snap-mandatory gap-6 overflow-x-auto px-4 pb-4 sm:-mx-6 sm:px-6 lg:-mx-8 lg:px-8"
    >
      {
        site.resenas.map((r) => (
          <div class="w-80 shrink-0 snap-start sm:w-96">
            <TestimonialCard quote={r.texto} author={r.autor} />
          </div>
        ))
      }
    </div>
  </section>

  <section class="bg-primary py-16 text-white">
    <div class="mx-auto flex max-w-7xl flex-col items-start gap-6 px-4 sm:px-6 lg:flex-row lg:items-center lg:justify-between lg:px-8">
      <div>
        <h2 class="font-display text-3xl font-bold sm:text-4xl">
          ¿Tienes una urgencia ahora mismo?
        </h2>
        <p class="mt-2 text-white/80">
          Servicio 24 horas, los 365 días del año, en toda Sevilla capital.
        </p>
      </div>
      <div class="flex flex-wrap gap-4">
        <UrgentCTA />
        <WhatsAppCTA />
      </div>
    </div>
  </section>
</BaseLayout>
