---
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/icons/Icon.astro';
import UrgentCTA from '../../components/UrgentCTA.astro';
import { site } from '../../data/site';
import fotoFlota from '../../assets/fotos/flota-furgonetas-mg-mantenimientos-sevilla.jpg';
import fotoFurgoneta from '../../assets/fotos/furgoneta-desatascos-control-plagas-sevilla.jpg';
---

<BaseLayout
  title="Sobre Nosotros | MG Mantenimientos Sevilla"
  description="Más de 25 años resolviendo desatascos y control de plagas en Sevilla capital. Empresa autorizada por la Junta de Andalucía, con garantía de precio."
>
  <section class="mx-auto max-w-4xl px-4 py-16 sm:px-6 lg:px-8">
    <h1 class="font-display text-4xl font-bold text-primary sm:text-5xl">
      Sobre nosotros
    </h1>

    <div class="mt-8 space-y-5 text-lg leading-relaxed text-ink/80">
      <p>
        {site.nombre} lleva más de 25 años resolviendo urgencias de desatascos,
        saneamiento y control de plagas en Sevilla capital. Empezamos como una
        pequeña empresa familiar y hoy seguimos con la misma filosofía: llegar
        rápido, resolver bien y no dejar al cliente esperando.
      </p>
      <p>
        Somos empresa autorizada por la Junta de Andalucía para realizar
        tratamientos de control de plagas, y contamos con equipos propios de
        inspección con cámara 360º que nos permiten localizar averías en
        tuberías sin necesidad de obra en la mayoría de los casos.
      </p>
      <p>
        Trabajamos las 24 horas, los 365 días del año, en toda Sevilla capital,
        porque sabemos que un atasco o una plaga no avisan ni esperan a que
        abra el horario de oficina.
      </p>
    </div>

    <div class="mt-10 rounded-2xl border border-accent/30 bg-accent/5 p-6">
      <div class="flex items-start gap-3">
        <Icon name="shield" class="mt-0.5 h-6 w-6 shrink-0 text-accent" />
        <div>
          <h2 class="font-display text-lg font-bold text-primary">
            Garantía de precio
          </h2>
          <p class="mt-1 text-ink/75">
            Igualamos o bajamos cualquier presupuesto de la competencia.
            Pídenos el tuyo sin compromiso antes de decidir.
          </p>
        </div>
      </div>
    </div>

    <div class="mt-10 grid gap-6 sm:grid-cols-2">
      <Image
        src={fotoFurgoneta}
        alt="Furgoneta rotulada de MG Mantenimientos con los teléfonos de desatascos y control de plagas en Sevilla"
        class="h-full w-full rounded-2xl object-cover shadow-sm"
        widths={[480, 800]}
        sizes="(max-width: 640px) 100vw, 400px"
        loading="lazy"
      />
      <Image
        src={fotoFlota}
        alt="Flota de vehículos de MG Mantenimientos, empresa de desatascos y control de plagas en Sevilla"
        class="h-full max-h-96 w-full rounded-2xl object-cover shadow-sm"
        widths={[480, 800]}
        sizes="(max-width: 640px) 100vw, 400px"
        loading="lazy"
      />
    </div>

    <div class="mt-10 grid gap-4 sm:grid-cols-2">
      {
        site.diferenciadores.map((d) => (
          <div class="flex items-start gap-3 rounded-xl bg-white p-5 shadow-sm">
            <Icon name="check" class="mt-0.5 h-5 w-5 shrink-0 text-accent" />
            <p class="text-sm font-medium text-ink/80">{d}</p>
          </div>
        ))
      }
    </div>

    <div class="mt-12 flex justify-center">
      <UrgentCTA />
    </div>
  </section>
</BaseLayout>
